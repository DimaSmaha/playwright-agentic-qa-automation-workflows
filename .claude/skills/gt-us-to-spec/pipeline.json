{
  "pipeline": "gt-us-to-spec",
  "description": "Pipeline A: User Story → Playwright spec — plan → ideate → batch TC generation → per-scenario spec loop → ship",
  "run_id_prefix": "gt",
  "artifact_root": ".workflow-artifacts/{run_id}",
  "phases": [
    {
      "id": "phase-0",
      "label": "Initialize",
      "skill": null,
      "reads": [],
      "writes": [],
      "on_failure": "stop",
      "action": "generate run_id, mkdir artifact_root, validate inputs"
    },
    {
      "id": "phase-1",
      "label": "Plan",
      "skill": "gt-story-planner",
      "reads": [],
      "writes": ["us.json", "scenarios.md"],
      "resume_skip_if": "us.json",
      "on_failure": "stop"
    },
    {
      "id": "phase-2",
      "label": "Ideation",
      "skill": "gt-test-ideation",
      "reads": ["us.json", "scenarios.md"],
      "writes": ["test-ideas.json", "test-ideas.md"],
      "resume_skip_if": "test-ideas.json",
      "on_failure": "stop"
    },
    {
      "id": "phase-3",
      "label": "Batch TC Generation",
      "skill": null,
      "reads": ["test-ideas.json"],
      "writes": [],
      "on_failure": "log-and-continue",
      "loop": {
        "type": "for-each-scenario",
        "source": "scenarios.md",
        "skip_if_marked": "[SKIP]",
        "iteration_phases": [
          {
            "id": "phase-3a",
            "label": "Test Case",
            "skill": "gt-test-case-generator",
            "reads": ["test-ideas.json"],
            "writes": ["tc-{index}.json"],
            "resume_skip_if": "tc-{index}.json",
            "on_failure": "log-and-continue-next-scenario"
          }
        ]
      }
    },
    {
      "id": "phase-4",
      "label": "Per-Scenario Spec Loop",
      "skill": null,
      "reads": ["tc-*.json"],
      "writes": [],
      "on_failure": "log-and-continue",
      "loop": {
        "type": "for-each-scenario",
        "source": "scenarios.md",
        "skip_if_marked": "[SKIP]",
        "iteration_phases": [
          {
            "id": "phase-4b",
            "label": "Spec Writer",
            "skill": "gt-spec-writer",
            "reads": ["tc-{index}.json"],
            "writes": ["spec-{index}.json"],
            "resume_skip_if": "spec-{index}.json",
            "on_failure": "log-and-continue-next-scenario",
            "routing": {
              "on_status_passing": "phase-4c",
              "on_status_failing": "phase-4b-bug"
            }
          },
          {
            "id": "phase-4b-bug",
            "label": "Bug Report (failing spec)",
            "skill": "ft-bug-reporter",
            "reads": ["spec-{index}.json", "tc-{index}.json"],
            "writes": ["bug-{index}.json"],
            "condition": "spec-{index}.json.status == 'failing'",
            "on_failure": "log-and-continue-next-scenario"
          },
          {
            "id": "phase-4c",
            "label": "Refactor",
            "skill": "gt-refactor-tests",
            "reads": ["spec-{index}.json"],
            "writes": [],
            "condition": "spec-{index}.json.status == 'passing'",
            "pipeline_mode": true,
            "on_failure": "log-and-continue-next-scenario"
          }
        ]
      }
    },
    {
      "id": "phase-5",
      "label": "Summary",
      "skill": null,
      "reads": ["spec-*.json"],
      "writes": [],
      "on_failure": "stop",
      "action": "emit final summary table"
    },
    {
      "id": "phase-6",
      "label": "Ship",
      "skill": "gf-ship",
      "reads": ["us.json", "spec-*.json"],
      "writes": [],
      "condition": "at least one spec-*.json has status == 'passing'",
      "on_condition_false": "warn-and-stop",
      "on_failure": "stop",
      "ship_params": {
        "work_item_id_template": "gt-{us_id}",
        "commit_type": "test",
        "commit_scope": "specs",
        "commit_subject_template": "add {passing_count} Playwright specs for story {us_id}",
        "files_template": "{all_passing_spec_paths}",
        "base": "${CORE_BRANCH:-master}"
      }
    }
  ],
  "compaction": {
    "enabled": true,
    "strategy": "emit-compact-block-then-drop",
    "phases": {
      "phase-1": { "retain": ["us_id", "title", "scenario_count"] },
      "phase-2": { "retain": ["total_ideas", "scenario_count"] },
      "phase-3a": { "retain": ["tc_id", "scenario_index", "title", "deduped"] },
      "phase-4b": { "retain": ["status", "spec_path", "tc_id", "last_error"] },
      "phase-4c": { "retain": ["fixes_applied", "spec_path"] }
    }
  }
}
